{
    "name": "falcon-pms-frontend",
    "version": "1.0.0",
    "description": "Falcon Performance Management System",
    "author": "Falcon ICT Department",
    "license": "MIT",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings",
        "lint:fix": "eslint . --ext js,jsx --fix",
        "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:watch": "jest --watch",
        "analyze": "source-map-explorer 'dist/assets/*.js'",
        "preview:build": "npm run build && npm run preview",
        "clean": "rm -rf dist node_modules package-lock.json",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.2.0",
        "@tanstack/react-query": "^5.100.1",
        "axios": "^1.6.7",
        "chart.js": "^4.4.1",
        "date-fns": "^3.3.1",
        "echarts": "^6.0.0",
        "formik": "^2.4.5",
        "jwt-decode": "^4.0.0",
        "lucide-react": "^1.7.0",
        "qr-code-styling": "^1.9.2",
        "react": "^18.2.0",
        "react-chartjs-2": "^5.2.0",
        "react-dom": "^18.2.0",
        "react-dropzone": "^15.0.0",
        "react-hot-toast": "^2.6.0",
        "react-icons": "^5.0.1",
        "react-redux": "^9.1.0",
        "react-router-dom": "^6.22.0",
        "redux-persist": "^6.0.0",
        "redux-persist-transform-encrypt": "^3.0.1",
        "yup": "^1.4.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.4.2",
        "@testing-library/react": "^14.2.1",
        "@testing-library/user-event": "^14.5.2",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "cssnano": "^7.1.5",
        "eslint": "^8.56.0",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "postcss": "^8.4.35",
        "prettier": "^3.2.5",
        "source-map-explorer": "^2.5.3",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3",
        "vite": "^5.1.0",
        "vite-plugin-compression": "^0.5.1",
        "vite-plugin-imagemin": "^0.6.1",
        "vitest": "^1.3.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "engines": {
        "node": ">=24.14.0",
        "npm": ">=11.9.0"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "setupFilesAfterEnv": [
            "<rootDir>/src/tests/setup.js"
        ],
        "moduleNameMapper": {
            "\\.(css|less|scss|sass)$": "identity-obj-proxy",
            "\\.(jpg|jpeg|png|gif|webp|svg)$": "<rootDir>/src/tests/__mocks__/fileMock.js"
        },
        "collectCoverageFrom": [
            "src/**/*.{js,jsx}",
            "!src/**/*.test.{js,jsx}",
            "!src/**/*.stories.{js,jsx}",
            "!src/main.jsx",
            "!src/vite-env.d.js"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 70,
                "functions": 70,
                "lines": 70,
                "statements": 70
            }
        }
    }
}
