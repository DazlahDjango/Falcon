# Falcon PMS Frontend Environment Variables (Example)
# Copy this file to .env and update values for your environment

# App Configuration
VITE_APP_NAME=Falcon PMS
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API Configuration
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# Authentication
VITE_TOKEN_REFRESH_THRESHOLD=300000
VITE_SESSION_TIMEOUT=28800000

# Feature Flags
VITE_ENABLE_MFA=true
VITE_ENABLE_SSO=false
VITE_ENABLE_AUDIT_LOGS=true
VITE_ENABLE_ADVANCED_REPORTS=false

# Security (Change these in production!)
VITE_STORAGE_ENCRYPT_KEY=your-secure-encryption-key-here
VITE_ENCRYPTION_KEY=your-encryption-key-here

# Monitoring
VITE_SENTRY_DSN=
VITE_ANALYTICS_ID=

# Demo Mode
VITE_DEMO_MODE=false

# Upload Limits
VITE_MAX_FILE_SIZE=5242880
VITE_MAX_AVATAR_SIZE=2097152

# Pagination
VITE_DEFAULT_PAGE_SIZE=20

# Theme
VITE_DEFAULT_THEME=light

# Language
VITE_DEFAULT_LANGUAGE=en

# Timezone
VITE_DEFAULT_TIMEZONE=Africa/Nairobi

# Currency
VITE_DEFAULT_CURRENCY=USD