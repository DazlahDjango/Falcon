# ============================================================================
# FALCON PMS - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# DJANGO CORE
# ----------------------------------------------------------------------------
DJANGO_SECRET_KEY='django-insecure-_@-gd%1$i7%motr$)^ig)ue$a#ear_$wkbhtpsjh2f^pir0#+('  # CHANGE IN PRODUCTION!
DJANGO_ENV=development  # Options: development, staging, production
DJANGO_DEBUG=True       # Must be False in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# ----------------------------------------------------------------------------
DB_NAME=falcon_pms
DB_USER=Dazlah
DB_PASSWORD=Dazl2006  # Use strong password in production
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer      # Set to 'require' in production

# ----------------------------------------------------------------------------
# REDIS & CELERY
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=                           # Set in production if Redis requires auth
CELERY_BROKER_URL=${REDIS_URL}            # Defaults to same Redis
CELERY_RESULT_BACKEND=${REDIS_URL}        # Defaults to same Redis

# ----------------------------------------------------------------------------
# JWT AUTHENTICATION
# ----------------------------------------------------------------------------
JWT_SIGNING_KEY=${DJANGO_SECRET_KEY}      # Defaults to Django secret key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ----------------------------------------------------------------------------
# MFA / 2FA
# ----------------------------------------------------------------------------
OTP_TOTP_ISSUER=FalconPMS

# ----------------------------------------------------------------------------
# SESSION & SECURITY
# ----------------------------------------------------------------------------
SESSION_COOKIE_AGE=1209600                 # 2 weeks in seconds
SESSION_COOKIE_SECURE=False                # True in production with HTTPS
CSRF_COOKIE_SECURE=False                   # True in production
SECURE_SSL_REDIRECT=False                  # True in production
SECURE_HSTS_SECONDS=31536000               # 1 year (used in production)
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL_ORIGINS=False                # Never True in production

# ----------------------------------------------------------------------------
# CSRF (Cross-Site Request Forgery)
# ----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATELIMIT_ENABLE=True
RATELIMIT_RATES=login=5/m,api=100/h        # Format: action=count/period

# ----------------------------------------------------------------------------
# EMAIL (SMTP)
# ----------------------------------------------------------------------------
# Development: Use console backend (emails printed to console)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend  # or 'console.EmailBackend' for dev
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key  # Get from SendGrid
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@falconpms.com

# ----------------------------------------------------------------------------
# AWS S3 (For production file storage)
# ----------------------------------------------------------------------------
# Only needed if using S3 for static/media files
AWS_ACCESS_KEY_ID=                          # Your AWS access key
AWS_SECRET_ACCESS_KEY=                      # Your AWS secret key
AWS_STORAGE_BUCKET_NAME=                    # Your S3 bucket name
AWS_S3_REGION_NAME=us-east-1                # e.g., us-east-1, eu-west-1
AWS_S3_CUSTOM_DOMAIN=                       # Optional: custom CDN domain

# ----------------------------------------------------------------------------
# SENTRY (Error Tracking)
# ----------------------------------------------------------------------------
# Get from: https://sentry.io/organizations/[org]/projects/[project]/keys/
SENTRY_DSN=                                 # Set in production for error tracking
SENTRY_ENVIRONMENT=${DJANGO_ENV}            # Defaults to DJANGO_ENV
SENTRY_TRACES_SAMPLE_RATE=0.1               # 0.1 = 10% of requests (0.5=50%, 1.0=100%)
SENTRY_PROFILES_SAMPLE_RATE=0.1             # Code profiling sample rate
SENTRY_RELEASE=falcon-pms@1.0.0              # Match your app version

# ----------------------------------------------------------------------------
# DJANGO ADMIN
# ----------------------------------------------------------------------------
ADMIN_URL=admin/                             # CHANGE in production! Use random string
ADMIN_EMAIL=admin@falconpms.com

# ----------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS
# ----------------------------------------------------------------------------
SENDGRID_API_KEY=                            # For email (alternative to SMTP password)
POSTHOG_API_KEY=                              # For product analytics
AMPLITUDE_API_KEY=                            # For user analytics