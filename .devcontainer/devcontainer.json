{
    "name": "Falcon PMS development environment",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/falcon-pms,type=bind,consistency=cached",
    "workspaceFolder": "/workspaces/falcon-pms",
    "postCreateCommand": "pip install -r requirements/development.txt",
    "forwardPorts": [8000, 5432, 6379],
    "remoteUser": "vscode"
}